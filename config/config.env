# ctrlg Configuration

# AI Model settings (기존 쉘 환경변수가 정의되어 있으면 덮어쓰지 않고 보존합니다)
OLLAMA_MODEL="${OLLAMA_MODEL:-gemma4-e2b-q4:latest}"
OLLAMA_HOST="${OLLAMA_HOST:-http://127.0.0.1:11434}"
TIMEOUT_SEC="${TIMEOUT_SEC:-15}"

# 자동 클립보드 복사 여부
AUTO_COPY_CLIPBOARD="${AUTO_COPY_CLIPBOARD:-true}"

# 명령어 실행 보안 화이트리스트
WHITELIST_COMMANDS="${WHITELIST_COMMANDS:-ls pwd df du date whoami ps free hostname cat grep find uname echo head tail wc awk xargs}"
